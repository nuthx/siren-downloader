{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "塞壬唱片下载器",
  "version": "../package.json",
  "identifier": "com.nuthx.siren-downloader",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "塞壬唱片下载器",
        "theme": "Dark",
        "width": 1200,
        "height": 760,
        "minWidth": 1000,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      },
      "capabilities": [
        {
          "identifier": "default",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "opener:default",
            "store:default",
            "dialog:default",
            "shell:allow-execute",
            {
              "identifier": "opener:allow-open-path",
              "allow": [{ "path": "$APPDATA" }]
            }
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/icon.icns",
      "../icons/icon.ico"
    ]
  }
}
